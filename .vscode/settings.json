{
    "chat.tools.terminal.autoApprove": {
        "/^git pull$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^git stash ; git pull$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^git add \\. ; git commit -m \"fix: documentation changes\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^git push$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^git add \\. ; git commit -m \"fix: review fixes\"$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}